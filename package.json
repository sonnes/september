{
  "name": "september",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @september/web dev",
    "build": "pnpm --filter @september/web build",
    "start": "pnpm --filter @september/web start",
    "lint": "pnpm -r lint",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@standard-schema/spec": "^1.1.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/lodash": "^4.17.20",
    "@types/node": "^20",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/uuid": "^10.0.0",
    "@types/wink-pos-tagger": "^2.2.6",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^27.3.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5",
    "vitest": "^4.0.16"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.7",
      "@types/react-dom": "19.2.3"
    }
  }
}
